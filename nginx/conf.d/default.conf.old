# Redirect all HTTP to HTTPS
server {
    listen 80;
    server_name byteon.richardlander.cornwall.sch.uk;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# Main HTTPS Server Block
server {
    listen 443 ssl;
    server_name byteon.richardlander.cornwall.sch.uk;

    ssl_certificate     /etc/letsencrypt/live/byteon.richardlander.cornwall.sch.uk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/byteon.richardlander.cornwall.sch.uk/privkey.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # 🔐 Auth-specific routes (login, logout, dashboard)
    location ~ ^/(login|dashboard|logout)$ {
        proxy_pass http://auth:5002;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 🏠 Root route (homepage) goes to auth container
    location = / {
        proxy_pass http://auth:5002;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 🌍 All other routes (must be logged in)
    location / {
        # Redirect to login if session cookie not present
        if ($http_cookie !~* "session=") {
            return 302 https://$host/login;
        }

        proxy_pass http://web:5001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
