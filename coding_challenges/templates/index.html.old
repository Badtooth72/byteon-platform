{% extends "base.html" %}
{% block title %}Python GCSE Programming Challenges{% endblock %}
{% block content %}
<div class="container">
  <h1 class="text-center mb-4">Python GCSE Programming Challenges</h1>
  
  <!-- Top Progress Bar -->
  <div class="mb-4">
    <div class="progress">
      <div id="top-progress-bar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
    </div>
  </div>
  
  <div class="row">
    <!-- Main Column for Challenges -->
    <div class="col-md-9">
      <div id="challenge-container">
        {% for ch in challenges %}
        <div class="challenge" id="challenge-{{ ch.challenge_id }}">
          <h2>Challenge {{ ch.challenge_id }}: {{ ch.title }} (Level {{ ch.level }})</h2>
          <p><strong>Description:</strong> {{ ch.description }}</p>
          <!-- Hidden fields for description and solution -->
          <input type="hidden" id="desc-{{ ch.challenge_id }}" value="{{ ch.description }}">
          <p><strong>Structures:</strong> {{ ch.structures }}</p>
          <p><strong>Example Output:</strong></p>
          <pre id="ex-{{ ch.challenge_id }}">{{ ch.example }}</pre>
          <p><strong>Solution (for quit):</strong></p>
          <input type="hidden" id="sol-{{ ch.challenge_id }}" value="{{ ch.solution }}">
          <div class="mb-2">
            <label for="code-{{ ch.challenge_id }}"><strong>Your Code:</strong></label>
            <textarea class="form-control" id="code-{{ ch.challenge_id }}" rows="10" placeholder="Type your code here..."></textarea>
          </div>
          <!-- Button group (all buttons on one row) -->
          <div class="btn-group mb-2" role="group">
            <button id="run-{{ ch.challenge_id }}" class="btn btn-info" onclick="runCode({{ ch.challenge_id }})">Run Code</button>
            <button id="submit-{{ ch.challenge_id }}" class="btn btn-primary" onclick="submitChallenge()">Submit</button>
            <button class="btn btn-secondary" onclick="getHelp()">Help</button>
            <button class="btn btn-danger" onclick="quitChallenge()">Quit</button>
          </div>
          <!-- Code output area -->
          <div class="mb-2">
            <label><strong>Code Output:</strong></label>
            <pre id="output-{{ ch.challenge_id }}" class="code-output"></pre>
          </div>
          <!-- Feedback and Score -->
          <div id="feedback-{{ ch.challenge_id }}" class="alert alert-info" style="display:none;"></div>
          <div id="score-{{ ch.challenge_id }}" class="mb-2"></div>
        </div>
        {% endfor %}
      </div>
      <!-- Navigation area under the challenge box, same width as challenge container -->
      <div class="challenge-nav mt-4">
        <button class="btn btn-outline-primary nav-button" onclick="prevChallenge()">Previous</button>
        <button class="btn btn-outline-primary nav-button" onclick="nextChallenge()">Next</button>
      </div>
    </div>
    
    <!-- Right-hand Column for Overall Progress Summary -->
    <div class="col-md-3">
      <div class="progress-list">
        <h5>Challenge Progress</h5>
        <div id="progress-summary">
          <!-- Progress items injected by JS -->
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
{% block scripts %}
<script src="{{ url_for('static', filename='main.js') }}"></script>
{% endblock %}
